# Unity Project .gitignore

# Place at root of Unity project

# =========================

# Unity Generated Folders

# =========================

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Crash reports

sysinfo.txt
mono_crash.*

# Memory captures (can be huge)

/[Mm]emoryCaptures/

# Recordings

/[Rr]ecordings/

# =========================

# Unity Meta Handling

# =========================

# (Keep .meta files, Unity requires them)

# =========================

# Visual Studio / IDE

# =========================

.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Rider

*.DotSettings.user

# Gradle

.gradle/

# Consulo

.consulo/

# Exported Obj

ExportedObj/

# =========================

# Logs

# =========================

*.log

# =========================

# Blender temp files

# =========================

*.blend1
*.blend1.meta

# =========================

# Android / Mobile Builds

# =========================

*.apk
*.aab

# =========================

# Unity Packages

# =========================

*.unitypackage
*.unitypackage.meta

# =========================

# Mac Builds

# =========================

*.app

# =========================

# Crashlytics

# =========================

crashlytics-build.properties

# =========================

# Addressables

# =========================

/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# =========================

# Visual Scripting

# =========================

/[Aa]ssets/Unity.VisualScripting.Generated/

# =========================

# Test Runner

# =========================

/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*